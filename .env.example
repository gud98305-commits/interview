# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# GPT 모델 (기본: gpt-4o-mini, 옵션: gpt-4o, gpt-4-turbo 등)
GPT_MODEL=gpt-4o-mini

# Whisper 모델 (음성 인식)
WHISPER_MODEL=whisper-1

# TTS 모델 및 음성 (질문 읽기)
TTS_MODEL=tts-1
TTS_VOICE=nova

# API 타임아웃 (초) — 숫자만 입력
API_TIMEOUT=30

# API 최대 재시도 횟수
API_MAX_RETRIES=2
